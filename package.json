{
  "name": "bdoom",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run start:dev --workspace apps/api",
    "build": "npm run build --workspace apps/web && npm run build --workspace apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "seed:admin": "npm run seed:admin --workspace apps/api --",
    "seed:brother": "npm run seed:brother --workspace apps/api --"
  }
}
